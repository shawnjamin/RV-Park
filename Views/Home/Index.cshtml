@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

@* Hero *@
<div class="px-4 py-5 my-5 text-center bg-dark text-white rounded-3 shadow">
    <h1 class="display-4 fw-bold">Welcome to RV Park</h1>
    <div class="col-lg-6 mx-auto">
        <p class="lead mb-4">Experience the great outdoors with premium amenities, spacious sites, and beautiful scenery. Book your next adventure today.</p>
    </div>
</div>

@* Site search bar *@
<div class="container mb-5" style="margin-top: -60px; position: relative; z-index: 10;">
    <div class="card shadow-lg border-0">
        <div class="card-body p-4">
            <form asp-controller="RvSites" asp-action="Browse" method="get">
                <div class="row g-3 align-items-end">
                    
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Check-In</label>
                        <input type="date" name="checkIn" class="form-control" required />
                    </div>
                    
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Check-Out</label>
                        <input type="date" name="checkOut" class="form-control" required />
                    </div>
                    
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Site Type</label>
                        <select name="siteType" class="form-select">
                            <option value="">Any Type</option>
                            <option value="Standard">Standard</option>
                            <option value="Premium">Premium</option>
                            <option value="Pull-Through">Pull-Through</option>
                            <option value="Tent">Tent</option>
                        </select>
                    </div>
                    
                    <div class="col-md-2">
                        <label class="form-label fw-bold">RV Length (ft)</label>
                        <input type="number" name="rvLength" class="form-control" placeholder="e.g. 30" />
                    </div>
                    
                    <div class="col-md-1">
                        <button type="submit" class="btn btn-primary w-100">Search</button>
                    </div>
                    
                </div>
            </form>
        </div>
    </div>
</div>

@* Park information grid *@
<div class="container my-5">
    <div class="row g-4 py-5 row-cols-1 row-cols-lg-3">
        
        <div class="col">
            <div class="h-100 p-4 bg-light border rounded-3">
                <h3 class="fw-bold">Park Amenities</h3>
                <ul class="mt-3 text-muted">
                    <li class="mb-2">Full Hookups (Water, Sewer, Electric)</li>
                    <li class="mb-2">High-Speed Wi-Fi</li>
                    <li class="mb-2">Clean Showers & Restrooms</li>
                    <li class="mb-2">Dog Park & Walking Trails</li>
                </ul>
            </div>
        </div>
        
        <div class="col">
            <div class="h-100 p-4 bg-light border rounded-3">
                <h3 class="fw-bold">Rates & Policies</h3>
                <p class="mt-3 text-muted">Check-in time is 2:00 PM and check-out is 11:00 AM. Quiet hours are strictly enforced from 10:00 PM to 7:00 AM.</p>
                <a href="#" class="btn btn-outline-secondary mt-2">View Full Policies</a>
            </div>
        </div>
        
        <div class="col">
            <div class="h-100 p-4 bg-light border rounded-3">
                <h3 class="fw-bold">Location</h3>
                <p class="mt-3 text-muted">Located just minutes from the national park entrance, offering the perfect basecamp for your hiking and sightseeing adventures.</p>
                <a href="#" class="btn btn-outline-secondary mt-2">Get Directions</a>
            </div>
        </div>
        
    </div>
</div>