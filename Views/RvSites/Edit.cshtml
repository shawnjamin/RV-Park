@model RVPark.Models.Site

@{
    ViewData["Title"] = "Edit RV Site";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2>Edit RV Site: @Model?.SiteNumber</h2>
        <p class="text-muted mb-0">Update physical parameters and availability.</p>
    </div>
    <a asp-action="ManagePhotos" asp-route-id="@Model?.Id" class="btn btn-warning shadow-sm">
        📸 Manage Site Photos
    </a>
</div>

<div class="row">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="SiteNumber" class="form-label fw-bold"></label>
                            <input asp-for="SiteNumber" class="form-control" />
                            <span asp-validation-for="SiteNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SiteTypeId" class="form-label fw-bold">Site Type</label>
                            <select asp-for="SiteTypeId" class="form-select" asp-items="ViewBag.SiteTypeId">
                                <option value="">Select a site type...</option>
                            </select>
                            <span asp-validation-for="SiteTypeId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="HookupType" class="form-label fw-bold"></label>
                            <select asp-for="HookupType" class="form-select" asp-items="Html.GetEnumSelectList<RVPark.Models.HookupType>()"></select>
                            <span asp-validation-for="HookupType" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SizeSqft" class="form-label fw-bold">Size (SqFt)</label>
                            <input asp-for="SizeSqft" class="form-control" type="number" />
                            <span asp-validation-for="SizeSqft" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notes" class="form-label fw-bold"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>

                    <div class="mb-4 form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" role="switch" id="isActiveSwitch" />
                        <label class="form-check-label" for="isActiveSwitch">Site is Active and Available for Rent</label>
                    </div>

                    <hr class="mb-4" />

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}