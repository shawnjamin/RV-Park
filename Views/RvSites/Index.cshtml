@model IEnumerable<RVPark.Models.Site>

@{
    ViewData["Title"] = "Manage RV Sites";
}

<partial name="_PageHeader" model='("Manage RV Sites", "Add New Site", Url.Action("Create"))' />

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Site Number</th>
                    <th>Type</th>
                    <th>Hookup</th>
                    <th>Size (SqFt)</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.SiteNumber</td>
                            <td>@item.SiteType?.Name</td>
                            <td>@item.HookupType</td>
                            <td>@item.SizeSqft</td>
                            <td>
                                <partial name="_StatusBadge" model='item.IsActive ? "Active" : "Inactive"' />
                            </td>
                            <td class="text-end">
                                
                                <a asp-action="ManagePhotos" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">
                                    📸 Photos
                                </a>

                                <partial name="_TableActionButtons" model="item.Id" />
                                
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">
                            No RV Sites found. Click "Add New Site" to get started!
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        <partial name="_DeleteModal" model='(item.Id, "RvSites")' /> 
    }
}