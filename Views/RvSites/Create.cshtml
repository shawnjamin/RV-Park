@model RVPark.Models.Site

@{
    ViewData["Title"] = "Add RV Site";
}

<h1>Add RV Site</h1>

<form asp-action="Create" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="SiteNumber" class="form-label"></label>
        <input asp-for="SiteNumber" class="form-control" />
        <span asp-validation-for="SiteNumber" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SiteTypeId" class="form-label"></label>
        <select asp-for="SiteTypeId" class="form-select" asp-items="ViewBag.SiteTypeId">
            <option value="">Select a site type</option>
        </select>
        <span asp-validation-for="SiteTypeId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="HookupType" class="form-label"></label>
        <select asp-for="HookupType" class="form-select" asp-items="Html.GetEnumSelectList<HookupType>()"></select>
        <span asp-validation-for="HookupType" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SizeSqft" class="form-label"></label>
        <input asp-for="SizeSqft" class="form-control" />
        <span asp-validation-for="SizeSqft" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PhotoUrl" class="form-label"></label>
        <input asp-for="PhotoUrl" class="form-control" />
        <span asp-validation-for="PhotoUrl" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
