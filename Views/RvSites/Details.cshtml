@model RVPark.Models.RvSite

@{
    ViewData["Title"] = "RV Site Details";
}

<h1>RV Site Details</h1>

<dl class="row mt-3">
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.SiteNumber)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.SiteNumber)</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.MaxRvLength)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.MaxRvLength) ft</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.NightlyRate)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.NightlyRate)</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.HookupType)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.HookupType)</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.IsAvailable)</dt>
    <dd class="col-sm-9">
        @if (Model.IsAvailable)
        {
            <span class="badge text-bg-success">Available</span>
        }
        else
        {
            <span class="badge text-bg-secondary">Unavailable</span>
        }
    </dd>
</dl>

<a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
<a class="btn btn-outline-secondary" asp-action="Index">Back to List</a>
