@model (string Title, string ButtonText, string ButtonUrl)

<div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4">
    <h2 class="mb-0">@Model.Title</h2>

    @if (!string.IsNullOrEmpty(Model.ButtonText))
    {
        <a href="@Model.ButtonUrl" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle"></i> @Model.ButtonText
        </a>
    }
</div>