@model RVPark.Models.Employee

@{
    ViewData["Title"] = "Employee Details";
}

<!-- Page title and helper text -->
<div class="mb-4">
    <h2>Employee Details</h2>
    <p class="text-muted">Review employee account information.</p>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">

        <!-- Details list for one employee -->
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.FirstName @Model.LastName</dd>

            <!-- Email is stored on the related User record -->
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.User.Email</dd>

            <dt class="col-sm-3">Access Level</dt>
            <dd class="col-sm-9">@Model.AccessLevel</dd>

            <!-- Show account status visually -->
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.IsLocked)
                {
                    <span class="badge bg-danger">Locked</span>
                }
                else
                {
                    <span class="badge bg-success">Active</span>
                }
            </dd>

            <!-- CreatedAt is stored on the related User record -->
            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">@Model.User.CreatedAt.ToLocalTime().ToString("MM/dd/yyyy")</dd>
        </dl>

        <hr />

        <!-- Navigation/action buttons -->
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        </div>
    </div>
</div>