@model IEnumerable<RVPark.Models.Employee>

@{
    ViewData["Title"] = "Employee Accounts";
}

<!-- Page header with title, description, and create button -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2>Employee Accounts</h2>
        <p class="text-muted mb-0">Create employees, update access levels, and lock accounts.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary">Create Employee</a>
</div>

<!-- Employee account list -->
<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Access Level</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var employee in Model)
                    {
                        <tr>
                            <!-- Employee name comes from the Employee model -->
                            <td class="fw-bold">@employee.FirstName @employee.LastName</td>

                            <!-- Email comes from the related User model -->
                            <td>@employee.User.Email</td>

                            <td>@employee.AccessLevel</td>

                            <!-- Show a badge depending on whether the account is locked -->
                            <td>
                                @if (employee.IsLocked)
                                {
                                    <span class="badge bg-danger">Locked</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                            </td>

                            <!-- Employee actions -->
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@employee.Id" class="btn btn-sm btn-outline-secondary">
                                    Details
                                </a>

                                <a asp-action="Edit" asp-route-id="@employee.Id" class="btn btn-sm btn-outline-primary">
                                    Edit
                                </a>

                                <!-- Lock/Unlock uses a POST form because it changes data -->
                                <form asp-action="ToggleLock" asp-route-id="@employee.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()

                                    @if (employee.IsLocked)
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-success">Unlock</button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Lock</button>
                                    }
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <!-- Message shown when there are no employees in the database -->
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">
                            No employee accounts found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>