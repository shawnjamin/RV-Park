@model IEnumerable<RVPark.Models.Reservation>

@{
    ViewData["Title"] = "Search Reservations";
}

@* Page header *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2>Manage Reservations</h2>
        <p class="text-muted">Search by Reservation Number or Customer Name.</p>
    </div>
</div>

@* Reservation search bar *@
<div class="card shadow-sm border-0 mb-4 bg-light">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-center">
            <div class="col-md-8">
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" name="searchQuery" class="form-control" placeholder="Enter Reservation # (e.g., RES-1042) or Customer Name..." />
                </div>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary btn-lg w-100">Search</button>
            </div>
        </form>
    </div>
</div>

@* Page body *@
<div class="card shadow-sm border-0">
    <div class="card-body">
        @* Reservations table*@
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Res #</th>
                    <th>Customer Name</th>
                    <th>Dates</th>
                    <th>Assigned Site</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @* Checks if the model exists, if yes, fills table data using the DB if not uses default message *@
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.ReservationNumber</td>
                            <td>@item.Customer?.FirstName @item.Customer?.LastName</td>
                            <td>
                                <div class="fw-bold">@item.StartDate.ToString("MMM dd, yyyy")</div>
                                <div class="text-muted small">to @item.EndDate.ToString("MMM dd, yyyy")</div>
                            </td>
                            <td>@item.Site?.SiteNumber</td>
                            <td>
                                <partial name="_StatusBadge" model='item.Status.ToString()' />
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Manage</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">
                            No reservations found. Try a different search query.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>