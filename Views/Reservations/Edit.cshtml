@model RVPark.Models.Reservation

@{
    ViewData["Title"] = "Manage Reservation";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h2>Manage Reservation #@(Model?.Id ?? 1042)</h2>
        <p class="text-muted mb-0">Modify dates, reassign sites, or cancel this booking.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to Search</a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Modify Booking Details</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <h5 class="border-bottom pb-2 mb-3">1. Adjust Dates</h5>
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label fw-bold">Check-In Date</label>
                            <input asp-for="StartDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label fw-bold">Check-Out Date</label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                        </div>
                    </div>

                    <h5 class="border-bottom pb-2 mb-3">2. Reassign Site</h5>
                    <div class="row mb-4">
                        <div class="col-md-8">
                            <label asp-for="SiteId" class="form-label fw-bold">Available Sites (for selected dates)</label>
                            <select asp-for="SiteId" class="form-select" asp-items="ViewBag.AvailableSites">
                                <option value="1">A-12 (Premium Pull-Through) - Current</option>
                                <option value="2">B-05 (Standard Tent) - Upgrade/Downgrade</option>
                            </select>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="button" class="btn btn-outline-primary w-100">Check Availability</button>
                        </div>
                    </div>

                    <hr class="my-4" />
                    
                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-success px-5">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Financial Impact</h5>
            </div>
            <div class="card-body bg-light">
                <p class="text-muted small mb-3">If you save the changes on the left, this is how the customer's balance will be affected.</p>
                
                <div class="d-flex justify-content-between mb-2">
                    <span>Original Total:</span>
                    <strong>$150.00</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>New Calculated Total:</span>
                    <strong>$200.00</strong>
                </div>
                
                <hr />
                
                <div class="alert alert-warning mb-0 text-center border-warning">
                    <h6 class="mb-1 fw-bold">Additional Payment Required</h6>
                    <h3 class="mb-0">$50.00</h3>
                </div>
                
                </div>
        </div>

        <div class="card shadow-sm border-0 border-danger">
            <div class="card-body text-center p-4">
                <h5 class="text-danger mb-3">Cancel Reservation</h5>
                <p class="text-muted small">Canceling this reservation will free up the assigned site and may trigger a cancellation fee based on the park's policy.</p>
                <form asp-action="Cancel" method="post">
                    <input type="hidden" name="id" value="@Model?.Id" />
                    <button type="submit" class="btn btn-outline-danger w-100 fw-bold" onclick="return confirm('WARNING: Are you sure you want to completely cancel this reservation?');">
                        Cancel Booking
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>