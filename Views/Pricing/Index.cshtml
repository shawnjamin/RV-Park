@model IEnumerable<RVPark.Models.SiteType>

@{
    ViewData["Title"] = "Maintain Pricing";
}

<partial name="_PageHeader" model='("Maintain Pricing & Site Types", "Add New Site Type", Url.Action("Create"))' />

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-striped table-hover align-middle mb-0">
            <!-- Table Column labels -->
            <thead class="table-dark">
                <tr>
                    <th>Site Type</th>
                    <th>Price</th>
                    <th>Valid Period</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @* Checks if the model exists, if yes, fills data using the DB if not uses filler *@
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold">@item.Name</div>
                                <small class="text-muted">@item.Description</small>
                            </td>
                            <td>@item.Price.ToString("C")</td>
                            <td>
                                <div class="small">
                                    <span class="text-muted">From:</span> @item.StartDate.ToString("MMM dd, yyyy")
                                </div>
                                <div class="small">
                                    <span class="text-muted">To:</span> 
                                    @(item.EndDate.HasValue ? item.EndDate.Value.ToString("MMM dd, yyyy") : "Current")
                                </div>
                            </td>
                            <td>
                                <partial name="_StatusBadge" model='item.IsActive ? "Active" : "Inactive"' />
                            </td>
                            <td class="text-end">
                                <partial name="_TableActionButtons" model="item.Id" />
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td>
                            <div class="fw-bold">Premium RV Site</div>
                            <small class="text-muted">Full hookups, pull-through</small>
                        </td>
                        <td>$75.00</td>
                        <td>
                            <div class="small"><span class="text-muted">From:</span> 01/01/2026</div>
                            <div class="small"><span class="text-muted">To:</span> Current</div>
                        </td>
                        <td><partial name="_StatusBadge" model='"Active"' /></td>
                        <td class="text-end"><partial name="_TableActionButtons" model="1" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Adds Delete Modal for each item (hidden by default) *@
@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        <partial name="_DeleteModal" model='(item.Id, "Pricing")' />
    }
}