@model RVPark.Models.SiteType

@{
    ViewData["Title"] = "Site Type Details";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <h2>Site Type Details</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Edit Type</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">@Html.DisplayFor(model => model.Name)</h5>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-muted">
                @Html.DisplayNameFor(model => model.Description)
            </dt>
            <dd class="col-sm-9">
                @(string.IsNullOrEmpty(Model?.Description) ? "No description provided." : Model.Description)
            </dd>

            <dt class="col-sm-3 text-muted">
                @Html.DisplayNameFor(model => model.Price)
            </dt>
            <dd class="col-sm-9 fw-bold text-success">
                @Html.DisplayFor(model => model.Price)
            </dd>

            <dt class="col-sm-3 text-muted">
                Status
            </dt>
            <dd class="col-sm-9">
                <partial name="_StatusBadge" model='Model?.IsActive == true ? "Active" : "Inactive"' />
            </dd>
        </dl>
    </div>
</div>