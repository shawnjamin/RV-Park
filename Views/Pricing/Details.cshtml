@model RVPark.Models.SiteType

@{
    ViewData["Title"] = "Pricing Details";
}

@* Details page header *@
<div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h2>Pricing Details</h2>
        <p class="text-muted mb-0">Review configuration for this pricing plan.</p>
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary me-2">Edit Plan</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

@* Details page body *@
<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">@Model?.Name</h5>
    </div>
    <div class="card-body">
        <dl class="row mb-0 p-2">
            <dt class="col-sm-3 text-muted mb-3">
                @Html.DisplayNameFor(model => model.Description)
            </dt>
            <dd class="col-sm-9 mb-3">
                @Model?.Description
            </dd>

            <dt class="col-sm-3 text-muted mb-3">
                @Html.DisplayNameFor(model => model.Price)
            </dt>
            <dd class="col-sm-9 fw-bold text-success mb-3">
                @Model?.Price.ToString("C")
            </dd>

            <dt class="col-sm-3 text-muted mb-3">@Html.DisplayNameFor(model => model.StartDate)</dt>
            <dd class="col-sm-9 mb-3">@Model?.StartDate.ToShortDateString()</dd>

            <dt class="col-sm-3 text-muted mb-3">@Html.DisplayNameFor(model => model.EndDate)</dt>
            <dd class="col-sm-9 mb-3">
                @{
                    string endDisplay = Model?.EndDate.HasValue == true ? Model.EndDate.Value.ToShortDateString() : "Current";
                }
                @endDisplay
            </dd>

            @* Status badge display w/ bool logic *@
            <dt class="col-sm-3 text-muted mb-3">Status</dt>
            <dd class="col-sm-9 mb-3">
                @{
                    bool active = Model != null && (Model.IsActive == true);
                }
                <partial name="_StatusBadge" model='(active ? "Active" : "Inactive")' />
            </dd>
        </dl>
    </div>
</div>