@model RVPark.Models.SiteType

@{
    ViewData["Title"] = "Edit Site Type";
}

<div class="mb-4">
    <h2>Edit Site Type: @Model?.Name</h2>
    <p class="text-muted">Update the details and pricing for this site category.</p>
</div>

<div class="row">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Price" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">$</span>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="StartDate" class="control-label">Pricing Start Date</label>
                        <input asp-for="StartDate" class="form-control" />
                        <span asp-validation-for="StartDate" class="text-danger">When does this rate begin?</span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="EndDate" class="control-label">Pricing End Date</label>
                        <input asp-for="EndDate" class="form-control" />
                        <span asp-validation-for="EndDate" class="text-danger">Leave blank for current price</span>
                    </div>

                    <div class="mb-4 form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" role="switch" id="isActiveSwitch" />
                        <label class="form-check-label" for="isActiveSwitch">Site Type is Active and Available</label>
                    </div>

                    <hr class="mb-4" />

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}