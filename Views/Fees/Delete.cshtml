@model RVPark.Models.Bill

@{
    // Sets the page title used by the shared layout.
    ViewData["Title"] = "Delete Fee";
}

@* ---------- Page Heading ---------- *@
<div class="mb-4">
    <h2>Delete Reservation Fee</h2>
    <p class="text-danger mb-0">Are you sure you want to delete this fee?</p>
</div>

@* ---------- Fee Summary ---------- *@
<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        @* Displays the identifying information for the fee before deletion. *@
        <dl class="row mb-0">
            <dt class="col-sm-3">Reservation</dt>
            <dd class="col-sm-9">@Model.Reservation?.ReservationNumber</dd>

            <dt class="col-sm-3">Customer</dt>
            <dd class="col-sm-9">
                @Model.Reservation?.Customer?.FirstName @Model.Reservation?.Customer?.LastName
            </dd>

            <dt class="col-sm-3">Fee Type</dt>
            <dd class="col-sm-9">@Model.Type</dd>

            <dt class="col-sm-3">Amount</dt>
            <dd class="col-sm-9">@Model.Amount.ToString("C")</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("MM/dd/yyyy")</dd>
        </dl>

        <hr />

        @* ---------- Delete Confirmation Form ---------- *@

        @* Submits to the POST Delete action after the user confirms deletion. *@
        <form asp-action="Delete">
            @* Preserves the ID of the fee that should be deleted. *@
            <input type="hidden" asp-for="Id" />

            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-danger">Delete Fee</button>
            </div>
        </form>
    </div>
</div>