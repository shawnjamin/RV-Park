@model IEnumerable<RVPark.Models.Bill>

@{
    ViewData["Title"] = "Manage Fees";
}

<partial name="_PageHeader" model='("Manage Fees", "Add New Fee", Url.Action("Create"))' />

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Reservation</th>
                    <th>Customer</th>
                    <th>Fee Type</th>
                    <th>Description</th>
                    <th>Amount</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var fee in Model) 
                    {
                        <tr>
                            <td class="fw-bold">@fee.Reservation?.ReservationNumber</td>
                            <td>
                                @fee.Reservation?.Customer?.FirstName @fee.Reservation?.Customer?.LastName
                            </td>
                            <td>@fee.Type</td>
                            <td>@fee.Description</td>
                            <td>@fee.Amount.ToString("C")</td>
                            <td>@fee.CreatedAt.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@fee.Id" class="btn btn-sm btn-outline-secondary">
                                    Details
                                </a>

                                <a asp-action="Edit" asp-route-id="@fee.Id" class="btn btn-sm btn-outline-primary">
                                    Edit
                                </a>

                                <a asp-action="Delete" asp-route-id="@fee.Id" class="btn btn-sm btn-outline-danger">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            No reservation fees found. Click "Add New Fee" to get started.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>