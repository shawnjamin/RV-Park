@model RVPark.Models.Bill

@{
    ViewData["Title"] = "Fee Details";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h2>Fee Details</h2>
        <p class="text-muted mb-0">Review the details of this specific charge.</p>
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary me-2">Edit Fee</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Charge: @Model?.Type.ToString()</h5>
        
        <span class="badge bg-success fs-6">@Model?.Amount.ToString("C")</span>
    </div>
    <div class="card-body">
        <dl class="row mb-0 p-2">
            <dt class="col-sm-3 text-muted mb-3">
                @Html.DisplayNameFor(model => model.ReservationId)
            </dt>
            <dd class="col-sm-9 fw-bold mb-3">
                @(Model?.Reservation?.ReservationNumber ?? Model?.ReservationId.ToString())
            </dd>

            <dt class="col-sm-3 text-muted mb-3">
                @Html.DisplayNameFor(model => model.Description)
            </dt>
            <dd class="col-sm-9 mb-3">
                @(string.IsNullOrEmpty(Model?.Description) ? "No description provided." : Model.Description)
            </dd>

            <dt class="col-sm-3 text-muted mb-3">
                Date Applied
            </dt>
            <dd class="col-sm-9 mb-3">
                @Model?.CreatedAt.ToString("MMM dd, yyyy h:mm tt")
            </dd>
        </dl>
    </div>
</div>